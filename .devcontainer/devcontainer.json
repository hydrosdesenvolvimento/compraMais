{
  "name": "compraMais (dev)",
  "dockerComposeFile": ["../docker-compose.yml", "docker-compose.devcontainer.yml"],
  "service": "backend",
  "workspaceFolder": "/workspaces/compraMais",
  "runServices": ["db", "backend", "frontend"],
  "shutdownAction": "stopCompose",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    },
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "forwardPorts": [3000, 5173, 5432],
  "portsAttributes": {
    "3000": { "label": "backend (Fastify)" },
    "5173": { "label": "frontend (Vite)" },
    "5432": { "label": "PostgreSQL/PostGIS" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-docker"
      ]
    }
  },
  "remoteUser": "node",
  "postCreateCommand": "cd backend && npm install && cd ../frontend && npm install"
}
