# .env consolidado do compraMais — usado pelo docker-compose.yml (profile dev).
# Copie para .env (NAO versionado) e ajuste localmente. PRJ-DEC-07: nenhum
# segredo real deve ser versionado. Em PRODUCAO, a senha do banco vem de um
# Docker secret (db_password), nao deste arquivo.

# --- Banco PostgreSQL/PostGIS (compartilhado pelos servicos) ---
POSTGRES_DB=compramais
POSTGRES_USER=compramais
# Apenas placeholder de DEV. Em prod use o Docker secret db_password.
POSTGRES_PASSWORD=changeme

# --- Portas publicadas em DEV ---
BACKEND_PORT=3000
FRONTEND_PORT=5173

# --- Backend ---
CORS_ORIGIN=*
# CNPJ/CEP via BrasilAPI (publica, sem chave). brasilapi (default) | mock (sem rede).
RECEITA_PROVIDER=brasilapi
# Politica de indisponibilidade de API de inadimplencia (AD-12): fail-open | fail-closed.
INADIMPLENCIA_POLICY=fail-open
# Prova de vida / liveness (UC007 / RF012) — CONDICIONAL A RIPD. Desligado por padrao: quando true, o
# Termo de Aceite exige liveness liberado. Ligar SO apos aprovacao do DPO (ver spec/docs/lgpd/RIPD-prova-de-vida.md).
LIVENESS_ENABLED=false
# Limiar de aprovacao do score de liveness (0..1). LIVENESS_PROVIDER: mock (default) | <provedor real>.
LIVENESS_LIMIAR=0.8
# Frontend (build-time, exposto ao browser): mostra a etapa de prova de vida no wizard quando true.
VITE_LIVENESS_ENABLED=false
# Limite global do malote SEI em MB (FR-003 / AD-21; valor real definido pela TI — LAC-05).
SEI_MALOTE_LIMITE_MB=10

# --- Autenticacao (FR-015 / AD-20) ---
# Segredo de assinatura do JWT (HS256). Use um valor forte; em PROD via Docker secret (jwt_secret).
JWT_SECRET=dev-secret-inseguro-trocar-em-producao
JWT_EXPIRES_IN_SECONDS=3600
# Google OAuth (vazio = login social desativado). Crie as credenciais no Google Cloud Console
# (ver docs/auth/google-cloud-setup.md) e preencha localmente — NUNCA versione o secret real.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
# Destino do redirect do browser apos o login Google (token JWT vai no fragmento da URL).
AUTH_FRONTEND_REDIRECT=http://localhost:5173/#/cadastro

# --- Producao (referencia para docker stack deploy) ---
# Repositorio GHCR no formato OWNER/REPO (ex.: minhaorg/compramais).
GHCR_REPOSITORY=OWNER/REPO
# Tag da imagem a implantar (ex.: sha-<commit> ou v1.2.3).
IMAGE_TAG=latest
# Porta publica do frontend em prod.
FRONTEND_PUBLIC_PORT=80
