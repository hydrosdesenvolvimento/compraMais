# Backend compraMais — exemplo de variaveis de ambiente (sem segredos reais).
# Copie para .env (nao versionado) e ajuste os valores localmente.

# --- Servidor ---
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

# --- CORS ---
# Em dev pode ser permissivo; em producao restrinja ao dominio do frontend.
CORS_ORIGIN=*

# --- Integracoes externas (ACL) — CNPJ e CEP via BrasilAPI (publica, sem chave) ---
# brasilapi (default) consulta https://brasilapi.com.br; mock usa dados sinteticos (sem rede).
RECEITA_PROVIDER=brasilapi

# --- Credenciamento: politica de indisponibilidade de API (AD-12) ---
# fail-open (default) libera com flag para a CPL ratificar; fail-closed bloqueia.
INADIMPLENCIA_POLICY=fail-open

# --- Malote SEI (FR-003 / AD-21) ---
# Limite GLOBAL do SEI municipal em MB (valor real definido pela TI — LAC-05).
SEI_MALOTE_LIMITE_MB=10

# --- Autenticacao (FR-015 / AD-20) ---
# Segredo de assinatura do JWT (HS256). Use valor forte; em PROD via Docker secret (JWT_SECRET_FILE).
JWT_SECRET=dev-secret-inseguro-trocar-em-producao
JWT_EXPIRES_IN_SECONDS=3600
# Google OAuth (vazio = login social desativado). Ver docs/auth/google-cloud-setup.md.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
AUTH_FRONTEND_REDIRECT=http://localhost:5173/#/cadastro

# --- Banco PostgreSQL/PostGIS ---
# host = nome do servico do banco na rede do Compose/Swarm.
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=compramais
POSTGRES_USER=compramais
# Em DEV: defina a senha aqui (apenas placeholder no .example).
POSTGRES_PASSWORD=changeme
# Em PROD: NAO use POSTGRES_PASSWORD; aponte para o Docker secret:
# POSTGRES_PASSWORD_FILE=/run/secrets/db_password
POSTGRES_SSL=false
POSTGRES_POOL_MAX=10
