{
  "name": "@compramais/backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend API do compraMais (Fastify + TypeScript, monolito modular / Clean Architecture)",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "seed": "tsx src/shared/db/seed.ts",
    "seed:prod": "node dist/shared/db/seed.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run tests/integration",
    "test:contract": "vitest run tests/contract",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/oauth2": "^8.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "fastify": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "opossum": "^8.1.4",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.1",
    "@types/opossum": "^8.1.9",
    "@types/pg": "^8.11.10",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^9.16.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^3.2.6"
  }
}
