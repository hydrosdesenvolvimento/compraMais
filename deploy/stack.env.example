# =========================================================================== #
# Variáveis de ambiente do stack de produção (deploy/compramais-stack.yml).    #
# =========================================================================== #
# No Portainer: cole estes pares na seção "Environment variables" do stack
#   (ou aponte este arquivo ao deployar "from Git").
# No CLI: `set -a && . ./stack.env && set +a` antes do `docker stack deploy`.
#
# NENHUM SEGREDO AQUI (PRJ-DEC-07). Senhas/chaves/JWT vêm de Docker secrets
# (db_password, jwt_secret, pii_encryption_key, sei_senha) — ver README.md.

# --- Origem das imagens (GHCR) ---
# Repositório no formato owner/repo, EM MINÚSCULAS (o GHCR normaliza assim).
GHCR_REPOSITORY=hydrosdesenvolvimento/compramais
# Tag a implantar. Prefira imutável (sha-<commit> ou vX.Y.Z) para releases
# rastreáveis; `latest` serve para o ambiente que acompanha o branch default.
IMAGE_TAG=latest

# --- Banco (PRJ-DEC-08) ---
POSTGRES_DB=compramais
POSTGRES_USER=compramais
# Para Postgres gerenciado (externo à stack), aponte host/porta e remova o
# serviço `db` do stack. A senha continua via secret db_password (*_FILE).
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Rede / domínio ---
# Porta pública do frontend (routing mesh). Coloque um proxy/TLS na frente em prod.
FRONTEND_PUBLIC_PORT=80
# Origem permitida no CORS do backend (o domínio público da aplicação).
CORS_ORIGIN=https://compramais.example
# URLs de callback/redirect do login Google (se habilitado).
GOOGLE_CALLBACK_URL=https://compramais.example/auth/google/callback
AUTH_FRONTEND_REDIRECT=https://compramais.example/#/cadastro

# --- Reconhecimento facial (UC007) ---
FACE_PROVIDER=insightface
FACE_SERVICE_URL=http://face:8000
FACE_MATCH_THRESHOLD=0.35
FACE_MIN_QUALITY=0.5
# Réplicas do serviço de ML (pesado). Suba conforme CPU disponível.
FACE_REPLICAS=1

# --- Domínio / providers ---
RECEITA_PROVIDER=brasilapi
INADIMPLENCIA_POLICY=fail-open
SEI_MALOTE_LIMITE_MB=10
JWT_EXPIRES_IN_SECONDS=3600

# --- Integração SEI (Épico 6) ---
# Default 'mock' (sem integração real). Para habilitar a integração 'web':
#   1) SEI_PROVIDER=web
#   2) preencha SEI_BASE_URL / SEI_USUARIO / SEI_SEL_ORGAO / SEI_ID_TIPO_PROCEDIMENTO
#   3) crie o secret `sei_senha`, aponte SEI_SENHA_FILE=/run/secrets/sei_senha e
#      descomente o secret no serviço `backend` e no bloco `secrets:` do stack.
SEI_PROVIDER=mock
SEI_BASE_URL=
SEI_USUARIO=
SEI_SEL_ORGAO=
SEI_ID_TIPO_PROCEDIMENTO=
SEI_SENHA_FILE=

# --- Google OAuth (opcional; vazio = login social desativado) ---
# O CLIENT_ID não é segredo; injete o CLIENT_SECRET pelo gestor de segredos do
# Portainer (não versionado). Deixe vazio para desabilitar o login social.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
