# Frontend compraMais — exemplo de variaveis de ambiente (sem segredos reais).
# Variaveis expostas ao browser DEVEM ter o prefixo VITE_.
# NUNCA coloque segredos aqui: tudo com VITE_ vai para o bundle publico.

# A SPA chama o backend em caminhos diretos (/fornecedores, /editais, /auditoria, ...).
# Esses prefixos sao encaminhados ao backend pelo proxy do Vite (dev) e do nginx (prod);
# como a navegacao usa hash routing (#/...), nao ha colisao entre rotas e API.

# Alvo do proxy de API no Vite dev server (nome do servico do backend na rede docker).
VITE_API_PROXY_TARGET=http://backend:3000
