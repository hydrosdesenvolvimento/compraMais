{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/cards/**",
              "components/core/**",
              "components/navigation/**",
              "ui_kits/portal/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Libre Franklin|IBM Plex Sans|Atkinson Hyperlegible))/i]",
        "message": "Font not provided by the design system. Available: Libre Franklin, IBM Plex Sans, Atkinson Hyperlegible."
      },
      {
        "selector": "JSXOpeningElement[name.name='A11yState'] > JSXAttribute > JSXIdentifier[name!=/^(?:fs|contrast|gray|hllinks|focusring|mask|noanim|readable|hideimg|key|ref|className|style|children)$/]",
        "message": "<A11yState> doesn't accept that prop. Declared props: fs, contrast, gray, hllinks, focusring, mask, noanim, readable, hideimg."
      },
      {
        "selector": "JSXOpeningElement[name.name='A11yState'] > JSXAttribute[name.name='fs'] > Literal[value!=/^(?:sm|md|lg|xl)$/]",
        "message": "<A11yState> fs must be one of 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|blue|accent)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'blue' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|disabled|iconLeft|iconRight|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, disabled, iconLeft, iconRight, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Footer'] > JSXAttribute > JSXIdentifier[name!=/^(?:style|key|ref|className|style|children)$/]",
        "message": "<Footer> doesn't accept that prop. Declared props: style."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavGroup'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|items|key|ref|className|style|children)$/]",
        "message": "<NavGroup> doesn't accept that prop. Declared props: label, items."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, strokeWidth."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|icon|variant|size|label|onClick|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: name, icon, variant, size, label, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ghost|outline|solid)$/]",
        "message": "<IconButton> variant must be one of 'ghost' | 'outline' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NewsCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:category|title|excerpt|credits|date|time|image|href|key|ref|className|style|children)$/]",
        "message": "<NewsCard> doesn't accept that prop. Declared props: category, title, excerpt, credits, date, time, image, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='PublicationRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:tag|title|meta|href|onDownload|key|ref|className|style|children)$/]",
        "message": "<PublicationRow> doesn't accept that prop. Declared props: tag, title, meta, href, onDownload."
      },
      {
        "selector": "JSXOpeningElement[name.name='SecretariaCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:sigla|kind|name|secretario|endereco|key|ref|className|style|children)$/]",
        "message": "<SecretariaCard> doesn't accept that prop. Declared props: sigla, kind, name, secretario, endereco."
      },
      {
        "selector": "JSXOpeningElement[name.name='ServiceCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|description|icon|status|href|cta|onClick|key|ref|className|style|children)$/]",
        "message": "<ServiceCard> doesn't accept that prop. Declared props: title, description, icon, status, href, cta, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|status|outline|key|ref|className|style|children)$/]",
        "message": "<StatusPill> doesn't accept that prop. Declared props: children, status, outline."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:success|warning|error|info)$/]",
        "message": "<StatusPill> status must be one of 'success' | 'warning' | 'error' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='VideoCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|credits|date|time|duration|image|href|key|ref|className|style|children)$/]",
        "message": "<VideoCard> doesn't accept that prop. Declared props: title, credits, date, time, duration, image, href."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
